# Server
PORT=4000
NODE_ENV=development

# Database (Supabase PostgreSQL direct connection)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# JWT Authentication
# Secret must be at least 32 characters — generate with: openssl rand -base64 48
JWT_SECRET=your-jwt-secret-at-least-32-characters-long
JWT_EXPIRES_IN=7d

# Supabase Storage
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Order Scheduler
# Auto-deliver threshold: orders in "delivering" status for >= N minutes → auto "delivered"
AUTO_DELIVERY_MINUTES=10
